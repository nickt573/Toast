{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toast",
  "version": "1.3.1",
  "identifier": "com.toast.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Toast",
        "width": 1000,
        "height": 830
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": [
        "$APPDATA/**",
        "$RESOURCE/**",
        "$HOME/**"
      ]
    }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNTc2Q0Y1MDUxMUY4RDEKUldUUitCRUY5V3hYMmw3ZnFVMWtmdWppTXdpK0U2cEhrZGRNUzEyVGhIcWNZREVrYW54d0FGdG8K",
      "endpoints": [
        "https://github.com/nickt573/Toast/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-libav"
        ]
      },
      "rpm": {
        "depends": [
          "gstreamer1-plugins-base",
          "gstreamer1-plugins-good",
          "gstreamer1-plugins-bad-free",
          "gstreamer1-libav"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}