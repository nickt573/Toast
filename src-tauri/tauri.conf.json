{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toast",
  "version": "0.1.0",
  "identifier": "com.toast.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Toast",
        "width": 1000,
        "height": 820
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": [
        "$APPDATA/**",
        "$RESOURCE/**",
        "$HOME/**"
      ]
    }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}